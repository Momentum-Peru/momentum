    "@angular/forms": "^20.2.0",
    "@angular/platform-browser": "^20.2.0",
    "@angular/router": "^20.2.0",
    "@azure/msal-angular": "^5.0.4",
    "@azure/msal-browser": "^5.2.0",
    "@primeuix/themes": "^1.2.5",
    "@types/uuid": "^11.0.0",
    "chart.js": "^4.5.1",
    "face-api.js": "^0.22.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "jszip": "^3.10.1",
    "primeicons": "^7.0.0",
    "primeng": "^20.2.0",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
