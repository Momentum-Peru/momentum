    "@tailwindcss/typography": "^0.5.10",
    "@types/jasmine": "~5.1.0",
    "@types/xlsx": "^0.0.35",
    "angular-eslint": "20.5.1",
    "eslint": "^9.38.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
